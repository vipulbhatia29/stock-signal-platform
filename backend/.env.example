# =============================================================================
# stock-signal-platform — Backend Environment Variables
# Copy this to backend/.env and fill in your values
# =============================================================================

# --- REQUIRED ---

# Anthropic API Key (for Claude Sonnet — primary LLM)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# JWT secret for authentication (min 32 random chars)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# Database (Postgres + TimescaleDB)
DATABASE_URL=postgresql+asyncpg://stocksignal:stocksignal@localhost:5433/stocksignal

# Redis (cache + Celery broker)
REDIS_URL=redis://localhost:6380/0

# --- OPTIONAL (add when needed) ---

# Groq API Key (fast/cheap fallback LLM for tool-calling loops)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI API Key (if you want GPT models as additional fallback)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# SerpAPI Key (for web/news search tool — 100 free searches/month)
# Get from: https://serpapi.com/manage-api-key
SERPAPI_API_KEY=

# FRED API Key (Federal Reserve macro data — yield curve, unemployment, etc.)
# Get from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- AUTH SETTINGS ---
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- APP SETTINGS ---
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=60
USER_TIMEZONE=America/New_York

# --- ADMIN SEED (first run only) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin1234

# --- FORECAST INTELLIGENCE ---
# Finnhub API Key (free tier: 60 calls/min)
# Get from: https://finnhub.io/dashboard
FINNHUB_API_KEY=

# Alpha Vantage (optional — additional market data)
ALPHA_VANTAGE_API_KEY=

# EDGAR user agent (SEC requires identifying user-agent)
EDGAR_USER_AGENT=StockSignalPlatform admin@example.com

# Sentiment scoring model (default: gpt-4o-mini)
NEWS_SCORING_MODEL=gpt-4o-mini

# Backtesting defaults
BACKTEST_MIN_TRAIN_DAYS=365
BACKTEST_STEP_DAYS=30

# Black-Litterman risk aversion (market consensus ~3.07)
BL_RISK_AVERSION=3.07

# Monte Carlo simulation count
MONTE_CARLO_SIMULATIONS=10000

# Pipeline failure mode: "continue" or "abort"
PIPELINE_FAILURE_MODE=continue

# --- LOGGING ---
LOG_LEVEL=DEBUG

# --- Langfuse (optional — observability tracing) ---
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASEURL=http://localhost:3001
LANGFUSE_NEXTAUTH_SECRET=changeme-langfuse-secret
LANGFUSE_SALT=changeme-langfuse-salt
